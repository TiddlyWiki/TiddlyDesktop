<?xml version="1.0" encoding="utf-8"?>
<!--
  The bundled Node.js server and the collab relay proxy run on loopback over plain
  HTTP. Permit cleartext ONLY for 127.0.0.1 / localhost. Serving wikis from loopback
  (not file://) is also what makes window.crypto.subtle available to the collab plugin
  (127.0.0.1 is a secure context in Chromium/WebView).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
