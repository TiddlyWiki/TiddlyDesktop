#!/bin/sh
# Auto-bump the collab plugin's patch version when its source changed in the commits being
# pushed but the version field wasn't already bumped. We can't add a commit to the push in
# progress, so we bump + commit and abort with a message — just run `git push` again to
# send it (now including the version bump).
#
# Enable once with:   ./bin/install-hooks.sh   (copies this into .git/hooks)

PLUGIN_DIR="plugins/codemirror-6-collab-nwjs"
INFO="$PLUGIN_DIR/plugin.info"
ZERO=0000000000000000000000000000000000000000

changed=0
infochanged=0

while read local_ref local_sha remote_ref remote_sha; do
	[ "$local_sha" = "$ZERO" ] && continue   # branch deletion
	if [ "$remote_sha" = "$ZERO" ]; then
		# New branch on the remote: compare against the upstream default if we can, else
		# against the empty tree (treat everything as new).
		base=$(git merge-base "$local_sha" origin/master 2>/dev/null || git hash-object -t tree /dev/null)
		range="$base..$local_sha"
	else
		range="$remote_sha..$local_sha"
	fi
	# Did any collab source file other than plugin.info change in the pushed commits?
	if git diff --name-only "$range" -- "$PLUGIN_DIR" 2>/dev/null | grep -qv "/plugin.info$"; then
		changed=1
	fi
	# Was the version field itself already changed in the pushed commits?
	if git diff "$range" -- "$INFO" 2>/dev/null | grep -q '"version"'; then
		infochanged=1
	fi
done

# Nothing to do: collab source unchanged, or the version was already bumped in this push.
[ "$changed" = "0" ] && exit 0
[ "$infochanged" = "1" ] && exit 0

node bin/bump-collab-version.js || exit 1
git add "$INFO"
git commit -m "Bump collab plugin version (auto)" >/dev/null
echo ""
echo "  ↑ collab plugin source changed — bumped its version and committed it."
echo "    Run 'git push' again to include the version bump."
echo ""
exit 1
